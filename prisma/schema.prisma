generator client {
  provider = "prisma-client-js"
}

/// Pooled (e.g. Neon `*-pooler.*`) for the app; optional separate direct URL for migrations.
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id               String            @id @default(cuid())
  type             ItemType
  status           ItemStatus        @default(OPEN)
  /// Poster (listings created while signed in)
  userId           String?
  title            String
  description      String
  category         ItemCategory
  building         String
  roomHint         String?
  contactName      String
  contactEmail     String?
  contactPhone     String?
  /// Legacy single image; if `imageUrls` is empty, this is still shown in the gallery
  imageUrl         String?
  /// Additional or primary gallery images (full URLs)
  imageUrls        String[]          @default([])
  color            String?
  brand            String?
  viewCount        Int               @default(0)
  /// When the item was lost or when it was found (user-facing date)
  eventDate        DateTime
  /// For lost listings: approximate time (free text, e.g. "2–4 PM")
  timeApprox       String?
  /// For found listings: where the item is now
  foundDisposition FoundDisposition?
  reward           String?
  notifyOnMatch    Boolean           @default(true)
  allowContact     Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  claims           Claim[]
  user             User?             @relation(fields: [userId], references: [id])

  @@index([type, status, eventDate])
  @@index([category, building])
  @@index([userId, type, status])
}

model Claim {
  id             String      @id @default(cuid())
  itemId         String
  userId         String
  type           ClaimType
  message        String
  proofImageUrls String[]    @default([])
  status         ClaimStatus @default(PENDING)
  adminNote      String?
  reviewedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  item           Item        @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
  @@index([itemId, status])
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole       @default(STUDENT)
  studentId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  claims        Claim[]
  items         Item[]
  notifications Notification[]
  sessions      Session[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind @default(SYSTEM)
  /// In-app path e.g. /items/abc or /claims
  link      String?
  title     String
  message   String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  STUDENT
  STAFF
  ADMIN
}

enum ItemType {
  LOST
  FOUND
}

enum ItemStatus {
  OPEN
  RESOLVED
  CLOSED
}

enum ItemCategory {
  ELECTRONICS
  DOCUMENTS
  KEYS
  CLOTHING
  BOOKS
  ACCESSORIES
  SPORTS
  STATIONERY
  BAGS
  OTHER
}

enum FoundDisposition {
  STILL_HAVE
  SUBMITTED_SECURITY
  LEFT_WHERE_FOUND
}

enum ClaimType {
  FINDER
  OWNER
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationKind {
  SYSTEM
  MATCH
  CLAIM
  ITEM
}
